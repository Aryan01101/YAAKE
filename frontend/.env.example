# ==============================================
# YAAKE Frontend Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# DO NOT commit the .env file to version control!

# ==============================================
# API CONFIGURATION
# ==============================================

# Backend API base URL
# Development: http://localhost:5001/api
# Production (Render): https://yaake-backend.onrender.com/api
# Production (Custom): https://your-api-domain.com/api
REACT_APP_API_BASE_URL=http://localhost:5001/api

# ==============================================
# DEPLOYMENT NOTES
# ==============================================
# - All React environment variables must start with REACT_APP_
# - Changes require a restart of the development server
# - For production builds, make sure to set the production API URL
#
# VERCEL DEPLOYMENT:
# 1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add: REACT_APP_API_BASE_URL = https://yaake-backend.onrender.com/api
# 3. Apply to: Production, Preview, Development
# 4. Redeploy from Deployments tab
#
# DOCKER DEPLOYMENT:
# Pass as build argument: --build-arg REACT_APP_API_BASE_URL=https://your-api-url.com/api
#
# NETLIFY DEPLOYMENT:
# Add environment variable in: Site Settings → Build & Deploy → Environment Variables
